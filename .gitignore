# ═══════════════════════════════════════════════════════════════
# cyber-cti-portfolio — Git ignore (GitHub + Vercel)
# ═══════════════════════════════════════════════════════════════

# --- Dependencies / package managers ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock

# --- Python local toolchain (builder.py) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/
.env/
.python-version
*.pyc

# --- Secrets / environment ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.*

# --- IDEs / editors ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.cursor/

# --- OS junk ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Logs / temp / local scratch ---
*.log
*.tmp
*.temp
*.bak
*.old
*.orig
*.swp
.cache/
tmp/
temp/
_audit_*.py
_test_*.py
_move_*.py

# --- Local image backups / placeholders ---
assets/images/backup/
assets/images/*.png.txt
*.png.txt

